# Open NotebookLM — Environment Configuration
# Copy to .env and adjust as needed.

# Папка данных (документы, индексы, конфиг). Задайте абсолютный путь, чтобы при запуске
# docker compose из любой папки использовались одни и те же данные (документы не пропадут):
# DATA_PATH=/Users/вас/путь/к/open-notebooklm/data

# LM Studio Local Server (runs on your host machine, NOT in Docker)
LMSTUDIO_BASE_URL=http://host.docker.internal:1234/v1
LMSTUDIO_MODEL=local-model

# ChromaDB (inside Docker)
CHROMA_HOST=chroma
CHROMA_PORT=8000

# Embedding model (sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2
